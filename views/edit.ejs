<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body>
    <div class="main w-full min-h-screen text-white bg-zinc-900 p-10 ">
        <a class="text-blue-500 mt-5 inline-block mb-10" href="/">Go Back to Home</a>

      
        <form action="/edit" method="post">
            <input  class="block bg-zinc-800 w-1/5 rounded-md" type="text" placeholder="Previous Name" value="<%= filename%>" name="previous" disabled="true">
            <input class="block mt-5  bg-zinc-800 w-1/5 rounded-md" type="text" placeholder="New Name" name="newname">
            <button class="text-white rounded-md mt-6 bg-yellow-400 px-2 py-1" type="submit"  >Update Name</button>
        </form>
        
    </div>


 
</body>
</html>